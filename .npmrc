# Supply-chain hardening (local development).
#
# axios is a RUNTIME dependency of this package (unlike the fetch variant, which has
# none), so its transitive tree — follow-redirects / form-data / proxy-from-env … — is
# installed locally and shipped to consumers. ignore-scripts blocks malicious
# postinstall hooks (Shai-Hulud-style worms) from running on `npm install`, and the
# cooldown avoids pulling a version published in the last 7 days.
#
# CI installs with `npm ci`, which uses the lockfile-pinned versions regardless of age,
# so the min-release-age cooldown does NOT gate it — every install is instead gated by
# `npm audit`. The cooldown only affects local `npm install` and the global
# `npm install -g` tooling. (Setting NPM_CONFIG_MIN_RELEASE_AGE=0 in CI is intentionally
# avoided: it is a no-op for `npm ci` and only misleads.)
ignore-scripts=true
min-release-age=7
