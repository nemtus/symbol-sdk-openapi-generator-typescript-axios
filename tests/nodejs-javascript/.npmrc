# Supply-chain cooldown: do not install versions published less than 7 days ago.
min-release-age=7

# The SDK is consumed via a `file:../../dist` dependency. npm symlinks directory
# file: deps (like `npm link`) and does NOT install their dependencies, so the SDK's
# runtime `axios` would be missing — `npm ci` would produce a tree where the SDK can't
# `require('axios')` (it only "worked" locally by falling back to the repo-root
# node_modules, which does not exist in the CI test jobs). install-links makes npm
# install file: deps like a real registry package (copied + their deps installed),
# so axios lands in this project's tree and the lockfile pins it. This is the axios
# variant's equivalent of the fetch variant needing nothing (fetch has no runtime deps).
install-links=true
